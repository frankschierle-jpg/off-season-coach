function checkGreeting(p){
  const last=DB.lastday(p.id);
  if(!last) return;
  try{
    const {day, date}=JSON.parse(last);
    const today=ds();
    // Only greet if last save was on a different day
    if(date===today) return;
    const nextDay=getNextTrainingDay(day);
    const nextPlan=PLAN[nextDay];
    // Auto-switch to next day
    curDay=nextDay;
    renderDayRow();
    renderDay(nextDay);
    // Show greeting
    showGreeting(p, day, nextDay, nextPlan);
  }catch(e){}
}

