function scToggle(){
  var btn=document.getElementById('sc_btn');
  var cueEl=document.getElementById('sc_cue');
  var subEl=document.getElementById('sc_sub');
  var cntEl=document.getElementById('sc_cnt');
  if(scActive){
    clearTimeout(scTimer);
    clearTimeout(sc_round_timer);
    scActive=false;
    if(btn){btn.textContent='▶ Neu starten';btn.classList.remove('stop');btn.onclick=function(){scToggle();};}
    if(cueEl){cueEl.textContent='GESTOPPT';cueEl.style.color='#fff';}
    if(subEl) subEl.textContent='';
    return;
  }
  sc_round=1; scRound=0; scActive=true;
  if(btn){btn.textContent='⏹ Stoppen';btn.classList.add('stop');btn.onclick=function(){scToggle();};}
  if(cueEl){cueEl.textContent='LOS!';cueEl.style.color='#4FC3F7';}
  if(subEl) subEl.textContent='Runde 1 von 3';
  if(cntEl) cntEl.textContent='Runde 1 / 3';
  sc_round_timer=setTimeout(function(){scEndRound();}, SC_ROUND_DURATION);
  scNext();
}
function scEndRound(){
  clearTimeout(scTimer);
  scActive=false;
  var cueEl=document.getElementById('sc_cue');
  var subEl=document.getElementById('sc_sub');
  var cntEl=document.getElementById('sc_cnt');
  var btn=document.getElementById('sc_btn');
  if(cueEl){cueEl.textContent='FERTIG!';cueEl.style.color='#27AE60';}
  if(cntEl) cntEl.textContent='Runde '+sc_round+' abgeschlossen';
  if(sc_round>=SC_ROUNDS){
    if(subEl) subEl.textContent='Alle 3 Runden geschafft!';
    if(btn){btn.textContent='▶ Nochmal';btn.classList.remove('stop');btn.onclick=function(){scToggle();};}
    return;
  }
  if(subEl) subEl.textContent='Bereit für Runde '+(sc_round+1)+'?';
  if(btn){
    btn.textContent='▶ Runde '+(sc_round+1)+' starten';
    btn.classList.remove('stop');
    btn.style.background='#27AE60'; btn.style.color='#fff';
    btn.onclick=function(){scStartNextRound();};
  }
}
function scStartNextRound(){
  sc_round++; scRound=0; scActive=true;
  var btn=document.getElementById('sc_btn');
  var cueEl=document.getElementById('sc_cue');
  var subEl=document.getElementById('sc_sub');
  var cntEl=document.getElementById('sc_cnt');
  if(btn){btn.textContent='⏹ Stoppen';btn.classList.add('stop');btn.style.background='';btn.style.color='';btn.onclick=function(){scToggle();};}
  if(cueEl){cueEl.textContent='LOS!';cueEl.style.color='#4FC3F7';}
  if(subEl) subEl.textContent='Runde '+sc_round+' von 3';
  if(cntEl) cntEl.textContent='Runde '+sc_round+' / 3';
  sc_round_timer=setTimeout(function(){scEndRound();}, SC_ROUND_DURATION);
  scNext();
}
function scNext(){
  if(!scActive) return;
  var cues=SC_CUES;
  var step=cues[scRound % cues.length];
  scTimer=setTimeout(function(){
    var cueEl=document.getElementById('sc_cue');
    var subEl=document.getElementById('sc_sub');
    if(cueEl){
      cueEl.textContent=step.cue;
      cueEl.style.color=step.color;
      cueEl.classList.add('pop');
      setTimeout(function(){if(cueEl)cueEl.classList.remove('pop');},150);
    }
    if(subEl) subEl.textContent=step.sub;
    scRound++;
    scNext();
  }, step.delay||1200);
}
