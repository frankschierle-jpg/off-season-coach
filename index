}

function msSaveAll(){
  const p=DB.get(CP.id),today=ds();let saved=0,fb=[];
  [['10',1.4,3.5],['20',2.2,5.0],['50',5.5,12]].forEach(([key,min,max])=>{
    const vals=[1,2,3].map(i=>{const v=parseFloat(document.getElementById(`ms_${key}_${i}`)?.value);return isNaN(v)?null:v}).filter(v=>v!==null&&v>=min&&v<=max);
    if(!vals.length)return;
    const best=Math.min(...vals),prev=p[`t${key}`];
    p[`times${key}`]=p[`times${key}`]||[];p[`times${key}`].push({d:today,v:best});p[`t${key}`]=best;saved++;
    const delta=prev?(best-prev).toFixed(2):null;
    if(delta&&delta<0)fb.push(`✅ ${key}m: ${best}s (${delta}s – schneller!)`);
    else if(delta&&delta>0)fb.push(`📊 ${key}m: ${best}s (+${delta}s)`);
    else fb.push(`📊 ${key}m: ${best}s (1. Messung)`);
  });
  if(!saved){alert('Bitte mindestens einen Versuch eingeben.');return}
  DB.save(p);CP=p;renderHdr(p);renderYouMarkers(p);
  document.getElementById('ms_feedback').innerHTML=`<div style="background:#F1F8E9;border:1.5px solid #A5D6A7;border-radius:10px;padding:12px;font-size:16px;line-height:1.8">${fb.join('<br>')}<br><strong style="color:var(--green)">Gespeichert!</strong></div>`;
}

