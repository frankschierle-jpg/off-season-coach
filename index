function ds(){return new Date().toLocaleDateString('de-DE',{day:'2-digit',month:'2-digit',year:'2-digit'})}

// ── REAL-TIME DATE & AUTO-DAY ──
const DAY_KEYS = ['so','mo','di','mi','do','fr','sa']; // JS: 0=Sun,1=Mon...
const WEEK_LABELS = ['Sonntag','Montag','Dienstag','Mittwoch','Donnerstag','Freitag','Samstag'];

function getTodayKey(){
  // Returns 'mo','di','mi','do','fr','sa','so'
  return DAY_KEYS[new Date().getDay()];
}

function getAutoWeek(p){
  // Calculate which week of the 6-week program we're in
  // based on profile creation date vs today
  if(!p || !p.createdAt) return p ? (p.week||1) : 1;
  try {
    const parts = p.createdAt.split('.');
    if(parts.length < 3) return p.week||1;
    const created = new Date(
      parseInt('20'+parts[2]), parseInt(parts[1])-1, parseInt(parts[0])
    );
    const now = new Date();
    const diffDays = Math.floor((now - created) / (1000*60*60*24));
    const week = Math.min(6, Math.max(1, Math.floor(diffDays/7) + 1));
    return week;
  } catch(e){ return p.week||1; }
}

function getGreetingTime(){
  const h = new Date().getHours();
  if(h < 10) return 'Guten Morgen';
  if(h < 13) return 'Guten Morgen';
  if(h < 17) return 'Guten Nachmittag';
  return 'Guten Abend';
}

function getFullDateStr(){
  return new Date().toLocaleDateString('de-DE', {
    weekday:'long', day:'2-digit', month:'long', year:'numeric'
  });
}

