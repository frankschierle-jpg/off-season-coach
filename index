function gngShowRoundResult(){
  var rd = gng_all_results[gng_all_results.length-1];
  if(!rd) return;
  var results = rd.results;
  var goHits = results.filter(function(r){ return r.isGo && r.correct && r.rt; });
  var falseAlarms = results.filter(function(r){ return !r.isGo && !r.correct; }).length;
  var misses = results.filter(function(r){ return r.isGo && r.miss; }).length;
  var total = results.length;
  var avg = goHits.length ? Math.round(goHits.reduce(function(a,r){ return a+r.rt; },0)/goHits.length) : null;
  var best = goHits.length ? Math.min.apply(null, goHits.map(function(r){ return r.rt; })) : null;
  var correct = results.filter(function(r){ return r.correct; }).length;
  var accuracy = total ? Math.round((correct/total)*100) : 0;
  var zone, zoneColor, zoneText;
  if(!avg){ zone='Keine Daten'; zoneColor='#888'; zoneText='Keine GO-Signale getippt'; }
  else if(avg<350){ zone='AUSGEZEICHNET'; zoneColor='#27AE60'; zoneText='Trainierter Fußballer-Level!'; }
  else if(avg<450){ zone='GUT'; zoneColor='#2ECC71'; zoneText='Überdurchschnittlich für 13-Jährige'; }
  else if(avg<550){ zone='DURCHSCHNITT'; zoneColor='#F39C12'; zoneText='Normaler Bereich – weiter trainieren'; }
  else { zone='LANGSAM'; zoneColor='#E74C3C'; zoneText='Viel Potenzial – täglich ueben!'; }

  var testName = rd.testId==='color'?'Farbpunkte':rd.testId==='shape'?'Formen':'Zahlen';
  var isLast = gng_round >= GNG_TESTS.length;
  var bar = document.getElementById('gng_result_bar');
  var btn = document.getElementById('gng_btn');

  if(bar){
    var html = '';
    html += '<div style="font-size:18px;font-weight:800;color:rgba(255,255,255,.6);margin-bottom:10px">Ergebnis Test ' + gng_round + ': ' + testName + '</div>';
    html += '<div style="text-align:center;margin-bottom:12px">';
    html += '<div style="font-family:\'Bebas Neue\',sans-serif;font-size:56px;color:' + zoneColor + '">' + (avg ? avg+'ms' : '--') + '</div>';
    html += '<div style="font-size:20px;font-weight:800;color:' + zoneColor + ';margin-bottom:4px">' + zone + '</div>';
    html += '<div style="font-size:17px;color:rgba(255,255,255,.4)">' + zoneText + '</div>';
    html += '</div>';
    html += '<div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:6px;margin-bottom:10px">';
    html += '<div style="background:rgba(255,255,255,.06);border-radius:6px;padding:10px;text-align:center"><div style="font-size:22px;font-weight:800;color:#fff">' + total + '</div><div style="font-size:17px;color:rgba(255,255,255,.35)">Gesamt</div></div>';
    html += '<div style="background:rgba(39,174,96,.15);border-radius:6px;padding:10px;text-align:center"><div style="font-size:22px;font-weight:800;color:#27AE60">' + goHits.length + '</div><div style="font-size:17px;color:rgba(255,255,255,.35)">Treffer</div></div>';
    html += '<div style="background:rgba(231,76,60,.15);border-radius:6px;padding:10px;text-align:center"><div style="font-size:22px;font-weight:800;color:#E74C3C">' + falseAlarms + '</div><div style="font-size:17px;color:rgba(255,255,255,.35)">Fehlklicks</div></div>';
    html += '<div style="background:rgba(243,156,18,.15);border-radius:6px;padding:10px;text-align:center"><div style="font-size:22px;font-weight:800;color:#F39C12">' + misses + '</div><div style="font-size:17px;color:rgba(255,255,255,.35)">Verpasst</div></div>';
    html += '</div>';
    html += '<div style="background:rgba(255,255,255,.06);border-radius:6px;padding:10px;text-align:center;font-size:16px">';
    html += 'Genauigkeit: <span style="color:#fff;font-weight:800">' + accuracy + '%</span>';
    if(best) html += '  |  Beste: <span style="color:#27AE60;font-weight:800">' + best + 'ms</span>';
    html += '</div>';
    bar.style.display = 'block';
    bar.innerHTML = html;
  }

  if(btn){
    if(isLast){
      btn.textContent = '▶ Alle Tests nochmal';
      btn.style.background = 'var(--y)';
      btn.style.color = 'var(--black)';
      btn.onclick = function(){ gngStart(gng_variant, gng_dayKey); };
      var saveBtn = document.getElementById('gng_save_btn');
      if(saveBtn) saveBtn.style.display = 'block';
    } else {
      var nextTest = GNG_TESTS[gng_round] || GNG_TESTS[0];
      btn.textContent = '▶ Test ' + (gng_round+1) + ' starten: ' + nextTest.title.split(' – ')[1];
      btn.style.background = '#27AE60';
      btn.style.color = '#fff';
      btn.onclick = function(){ gngStartRound(); };
    }
  }
  var sub = document.getElementById('gng_sub');
  if(sub) sub.textContent = isLast ? 'Alle 3 Tests abgeschlossen!' : 'Pause – dann Test ' + (gng_round+1) + ' starten';
  // Store for save
  if(isLast){
    var rounds = gng_all_results.map(function(rd2){
      var rH = rd2.results.filter(function(r){ return r.isGo && r.correct && r.rt; });
      return {round:rd2.round, testId:rd2.testId, avg:rH.length?Math.round(rH.reduce(function(a,r){return a+r.rt;},0)/rH.length):null, errors:rd2.results.filter(function(r){return !r.correct;}).length};
    });
    window._gng_last = {date:ds(), day:gng_dayKey, variant:'all3', avg:avg, best:best, accuracy:accuracy, errors:falseAlarms+misses, total:total, zone:zone, rounds:rounds};
  }
}

function gngSave(){
