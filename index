let CP=null,curDay='mo';

function launch(p){
  CP=p;
  document.getElementById('login').style.display='none';
  document.getElementById('app').style.display='block';
  document.getElementById('hdr_name').innerHTML=p.name.toUpperCase()+'<span> · U'+p.age+'</span>';
  document.getElementById('wsel').value=p.week||1;
  renderHdr(p);renderDayRow();renderDay(curDay);
  renderYouMarkers(p);renderSelfCheckForm();renderAnalysisHistory();
  renderHistoryPanel();
  // Check if returning next day after saved training
  setTimeout(()=>checkGreeting(p), 200);
}

function renderHdr(p){
  const w=p.week||1,pct=Math.round(((w-1)/5)*83+17);
  document.getElementById('prog_fill').style.width=pct+'%';
  document.getElementById('prog_lbl').textContent=`WOCHE ${w} VON 6`;
  document.getElementById('prog_pct').textContent=pct+'%';
  [['10',p.t10,p.times10,B10,imp10],['20',p.t20,p.times20,B20,imp20],['50',p.t50,p.times50,B50,imp50]].forEach(([d,t,times,B,ifn])=>{
    if(!t){document.getElementById(`sh_t${d}`).textContent='--';return}
    const im=ifn(t),goal=(t-im).toFixed(2);
    document.getElementById(`sh_t${d}`).textContent=goal+'s';
    const sl=(times||[]).slice().reverse().slice(0,3);
    document.getElementById(`sh_e${d}`).innerHTML=sl.map((e,i)=>{
      const prev=sl[i+1];const delta=prev?((e.v-prev.v)).toFixed(2):null;
      const cls=delta&&delta<0?'better':delta&&delta>0?'worse':'';
      return `<div class="spd-entry"><span class="spd-edate">${e.d}</span><span class="spd-eval">${e.v}s</span><span class="spd-edelta ${cls}">${delta?(delta<0?delta+'s':'+'+delta+'s'):'Start'}</span></div>`;
    }).join('');
    const g=grp(t,B);const badge=document.getElementById(`sh_g${d}`);
    badge.textContent=g.s;badge.style.color=g.c;badge.style.borderColor=g.c;badge.style.background=g.c+'18';
    document.getElementById(`sh_p${d}`).textContent=`Ziel: −${im.toFixed(2)}s`;
  });
}

function renderYouMarkers(p){
  [['10',p.t10,B10],['20',p.t20,B20],['50',p.t50,B50]].forEach(([d,t,B])=>{
    const m=document.getElementById(`ym${d}`);
    if(!t||!m){if(m)m.style.display='none';return}
    const g=grp(t,B);m.style.display='block';
    m.innerHTML=`Du (${t}s) → <strong style="color:${g.c}">${g.s}</strong>`;
  });
}

function setWoche(w){
  const p=DB.get(CP.id);p.week=parseInt(w);DB.save(p);CP=p;
