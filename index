<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Off Season Coach</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;500;600;700;800&family=Barlow+Condensed:wght@600;700;800&display=swap" rel="stylesheet">
<!-- iOS PWA / Home Screen App Icon -->
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Off Season Coach">
<meta name="theme-color" content="#0A0A0A">
<link id="apple-touch-icon-link" rel="apple-touch-icon">
<script>
// Generate OC logo: yellow bg, football as O, C in black
(function(){
  try {
    var c = document.createElement('canvas');
    c.width = 180; c.height = 180;
    var ctx = c.getContext('2d');

    // ── Yellow rounded background ──
    ctx.beginPath();
    var r = 32;
    ctx.moveTo(r, 0); ctx.lineTo(180-r, 0);
    ctx.quadraticCurveTo(180, 0, 180, r);
    ctx.lineTo(180, 180-r);
    ctx.quadraticCurveTo(180, 180, 180-r, 180);
    ctx.lineTo(r, 180);
    ctx.quadraticCurveTo(0, 180, 0, 180-r);
    ctx.lineTo(0, r);
    ctx.quadraticCurveTo(0, 0, r, 0);
    ctx.closePath();
    ctx.fillStyle = '#FFD600';
    ctx.fill();

    // ── Football "O" – left side ──
    // Ball circle
    var bx = 52, by = 90, br = 42;
    ctx.beginPath();
    ctx.arc(bx, by, br, 0, Math.PI * 2);
    ctx.fillStyle = '#FFFFFF';
    ctx.fill();
    ctx.lineWidth = 3.5;
    ctx.strokeStyle = '#0A0A0A';
    ctx.stroke();

    // Pentagon pattern on ball (classic soccer ball)
    function drawPentagon(ctx, cx, cy, size, angle) {
      ctx.beginPath();
      for (var i = 0; i < 5; i++) {
        var a = angle + (i * 2 * Math.PI / 5) - Math.PI / 2;
        var x = cx + size * Math.cos(a);
        var y = cy + size * Math.sin(a);
        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
      }
      ctx.closePath();
    }

    // Center pentagon
    drawPentagon(ctx, bx, by, 11, 0);
    ctx.fillStyle = '#0A0A0A';
    ctx.fill();

    // 5 surrounding pentagons
    var offsets = [0, 1, 2, 3, 4];
    offsets.forEach(function(i) {
      var a = (i * 2 * Math.PI / 5) - Math.PI / 2;
      var px = bx + 22 * Math.cos(a);
      var py = by + 22 * Math.sin(a);
      drawPentagon(ctx, px, py, 9, a + Math.PI / 5);
      ctx.fillStyle = '#0A0A0A';
      ctx.fill();
    });

    // Clip ball to circle (remove pentagons outside)
    ctx.save();
    ctx.beginPath();
    ctx.arc(bx, by, br - 1, 0, Math.PI * 2);
    ctx.clip();
    // Redraw pentagons inside clip
    drawPentagon(ctx, bx, by, 11, 0);
    ctx.fillStyle = '#0A0A0A';
    ctx.fill();
    offsets.forEach(function(i) {
      var a = (i * 2 * Math.PI / 5) - Math.PI / 2;
      var px = bx + 22 * Math.cos(a);
      var py = by + 22 * Math.sin(a);
      drawPentagon(ctx, px, py, 9, a + Math.PI / 5);
      ctx.fillStyle = '#0A0A0A';
      ctx.fill();
    });
    ctx.restore();

    // Ball outline again on top
    ctx.beginPath();
    ctx.arc(bx, by, br, 0, Math.PI * 2);
    ctx.lineWidth = 3.5;
    ctx.strokeStyle = '#0A0A0A';
    ctx.stroke();

    // ── "C" – right side ──
    ctx.beginPath();
    ctx.arc(118, 90, 36, Math.PI * 0.35, Math.PI * 1.65);
    ctx.strokeStyle = '#0A0A0A';
    ctx.lineWidth = 14;
    ctx.lineCap = 'round';
    ctx.stroke();

    // ── Set as apple-touch-icon ──
    var link = document.getElementById('apple-touch-icon-link');
    if (link) link.href = c.toDataURL('image/png');

    // Also set favicon
    var fav = document.querySelector("link[rel*='icon']");
    if (!fav) { fav = document.createElement('link'); fav.rel = 'icon'; document.head.appendChild(fav); }
    fav.type = 'image/png';
    fav.href = c.toDataURL('image/png');
  } catch(e) {}
})();
</script>
<style>
:root{
  --bg:#E6E6E6;--bg2:#D8D8D8;--card:#FFF;--card2:#EFEFEF;
  --border:#C8C8C8;--text:#111;--text2:#333;--muted:#555;
  --black:#0A0A0A;--y:#FFD600;--y2:#FFC000;--yl:rgba(255,214,0,.14);
  --yb:rgba(255,214,0,.35);--red:#C62828;--green:#2E7D32;--blue:#1565C0;
  --r:14px;--sh:0 2px 10px rgba(0,0,0,.08);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
button,a,[onclick]{touch-action:manipulation;cursor:pointer}
html,body{background:var(--bg);color:var(--text);font-family:'Barlow',sans-serif;min-height:100vh;overscroll-behavior:none}

/* ── LOGIN ── */
#login{display:flex;flex-direction:column;align-items:center;padding:28px 16px 40px}
.logo{font-family:'Bebas Neue',sans-serif;font-size:72.8px;color:var(--black);letter-spacing:2px;line-height:1;text-align:center}
.logo span{color:var(--y)}
.tagline{font-size:16px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);font-weight:700;text-align:center;margin-bottom:22px;margin-top:4px}
.lcard{background:var(--card);border-radius:18px;padding:22px;width:100%;max-width:500px;border:1px solid var(--border);box-shadow:0 6px 28px rgba(0,0,0,.10)}
.lsec{font-size:16px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);font-weight:800;margin-bottom:12px}
.lgrid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.fg label{display:block;font-size:16px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--text2);margin-bottom:4px}
.fg input{width:100%;background:var(--bg);border:1.5px solid var(--border);border-radius:9px;color:var(--text);font-family:'Barlow',sans-serif;font-size:20.8px;padding:10px 11px;outline:none;transition:border-color .15s;touch-action:manipulation}
.fg input:focus{border-color:var(--y)}
.ldiv{height:1px;background:var(--border);margin:16px 0}
.sinput{background:var(--bg);border-radius:11px;padding:13px;border:1px solid var(--border);margin-bottom:9px}
.sinput .sl{font-size:16px;font-weight:700;color:var(--text2);margin-bottom:9px}
.preview{background:var(--yl);border:1.5px solid var(--yb);border-radius:11px;padding:14px;margin-top:12px;display:none}
.prev-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;padding-bottom:8px;border-bottom:1px solid rgba(255,214,0,.2)}
.prev-row:last-of-type{border-bottom:none;margin-bottom:0;padding-bottom:0}
.prev-dist{font-size:16px;font-weight:800;color:var(--black)}
.prev-right{text-align:right}
.prev-curr{font-family:'Bebas Neue',sans-serif;font-size:28.6px;color:var(--black);line-height:1}
.prev-goal{font-size:16px;font-weight:700;color:var(--green);margin-top:1px}
.prev-grp{font-size:16px;color:var(--muted);margin-top:1px;font-weight:600}
.prev-note{font-size:16px;color:var(--text2);margin-top:10px;line-height:1.6;border-top:1px solid rgba(255,214,0,.2);padding-top:8px}
.lbtn{width:100%;background:var(--y);color:var(--black);border:none;border-radius:11px;font-family:'Barlow',sans-serif;font-weight:800;font-size:22.1px;padding:15px;cursor:pointer;margin-top:16px;box-shadow:0 4px 14px rgba(255,214,0,.3);letter-spacing:.3px;transition:transform .1s;touch-action:manipulation;-webkit-tap-highlight-color:rgba(255,214,0,.3)}
.lbtn:active{transform:scale(.98)}
.ep-wrap{margin-top:14px}
.ep-lbl{font-size:16px;font-weight:700;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:8px}

/* ── APP ── */
#app{display:none;min-height:100vh}

/* HEADER */
.hdr{background:#D0D0D0;padding:14px 16px 0;position:relative;overflow:hidden;border-bottom:3px solid var(--black)}
.hdr::before{content:'';position:absolute;top:-70px;right:-70px;width:220px;height:220px;border-radius:50%;background:radial-gradient(circle,rgba(255,214,0,.18) 0%,transparent 70%);pointer-events:none}
.hdr-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.hdr-name{font-family:'Bebas Neue',sans-serif;font-size:36.4px;color:var(--black);letter-spacing:1px}
.hdr-name span{font-size:23.4px;opacity:.6}
.hdr-right{display:flex;gap:6px;align-items:center}
.wsel{background:#fff;border:1.5px solid var(--border);border-radius:8px;color:var(--black);font-family:'Barlow',sans-serif;font-size:16px;padding:6px 8px;outline:none;font-weight:700}
.hbtn{background:#fff;border:1.5px solid var(--border);border-radius:8px;color:var(--text2);font-size:16px;font-family:'Barlow',sans-serif;font-weight:700;padding:6px 10px;cursor:pointer}
.hbtn.del{color:var(--red);border-color:rgba(198,40,40,.25)}

/* SPEED PANELS */
.spd-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;padding:0 14px}
.spd-box{background:#fff;border:1.5px solid var(--border);border-radius:11px;padding:11px 10px;position:relative;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.spd-box::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:var(--y)}
.spd-dist{font-size:16px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:4px}
.spd-target{font-family:'Bebas Neue',sans-serif;font-size:44.2px;color:var(--black);line-height:1}
.spd-tlbl{font-size:16px;color:var(--muted);font-weight:600;letter-spacing:.8px;text-transform:uppercase;margin-bottom:6px}
.spd-entries{margin-top:3px}
.spd-entry{display:flex;justify-content:space-between;align-items:center;padding:3px 0;border-bottom:1px solid var(--border)}
.spd-entry:last-child{border-bottom:none}
.spd-edate{font-size:16px;color:var(--muted)}
.spd-eval{font-family:'Barlow Condensed',sans-serif;font-size:18.2px;font-weight:700;color:var(--text2)}
.spd-edelta{font-size:16px;font-weight:800}
.spd-edelta.better{color:#2E7D32} .spd-edelta.worse{color:#C62828}
.spd-badge{font-size:16px;font-weight:800;margin-top:5px;border-radius:5px;padding:2px 6px;display:inline-block;border:1px solid}
.spd-pot{font-size:16px;color:var(--muted);margin-top:3px;border-top:1px solid var(--border);padding-top:4px}
.hdr-prog{padding:12px 14px 14px}
.hdr-prog-row{display:flex;justify-content:space-between;margin-bottom:4px;font-size:16px;font-weight:800;letter-spacing:.5px}
.hdr-prog-row span:first-child{color:var(--text2)}
.hdr-prog-row span:last-child{color:var(--black);background:var(--y);padding:1px 7px;border-radius:4px}
.hdr-prog-bg{background:var(--border);border-radius:100px;height:5px;overflow:hidden}
.hdr-prog-fill{height:100%;border-radius:100px;background:var(--y);transition:width .7s ease}
.recbtn-row{padding:0 14px 14px;display:flex;gap:7px}
.rbtn{flex:1;background:var(--black);border:none;border-radius:9px;color:var(--y);font-family:'Barlow',sans-serif;font-weight:800;font-size:16px;padding:10px 8px;cursor:pointer;text-align:center;letter-spacing:.3px}

/* TABS */
.tabs{background:var(--bg);display:flex;gap:5px;padding:11px 14px 0;overflow-x:auto;scrollbar-width:none;border-top:2px solid var(--black)}
.tabs::-webkit-scrollbar{display:none}
.tab{flex-shrink:0;background:var(--card);border:1.5px solid var(--border);border-radius:100px;padding:12px 18px;font-size:16px;font-weight:700;color:var(--muted);cursor:pointer;transition:all .15s;white-space:nowrap}
.tab.active{background:var(--black);color:var(--y);border-color:var(--black)}

/* PANELS */
.panel{display:none;padding:13px}
.panel.active{display:block}
.ptitle{font-family:'Bebas Neue',sans-serif;font-size:35.1px;letter-spacing:1px;color:var(--black);margin-bottom:2px}
.psub{font-size:16px;color:var(--muted);margin-bottom:13px;letter-spacing:1.5px;text-transform:uppercase;font-weight:800}

/* DAY BUTTONS */
.dayrow{display:flex;gap:5px;overflow-x:auto;scrollbar-width:none;padding-bottom:2px;margin-bottom:13px}
.dayrow::-webkit-scrollbar{display:none}
.daybtn{flex-shrink:0;background:var(--card);border:1.5px solid var(--border);border-radius:9px;padding:11px 12px;cursor:pointer;text-align:center;min-width:60px;transition:all .15s}
.daybtn.active{background:var(--black);border-color:var(--black)}
.daybtn .dn{font-size:16px;font-weight:800;text-transform:uppercase;color:var(--muted);letter-spacing:.5px}
.daybtn.active .dn{color:var(--y)}
.daybtn .di{font-size:16px;margin-top:1px}

/* PROGRAM BLOCK HEADERS */
.prog-block{border-radius:14px;margin-bottom:14px;border:1.5px solid var(--border);box-shadow:var(--sh)}
.prog-block-hdr{padding:13px 14px;display:flex;align-items:center;gap:12px}
.prog-block-hdr.sprint-hdr{background:var(--black);border-radius:12px 12px 0 0}
.prog-block-hdr.ball-hdr{background:#1a1a2e;border-radius:12px 12px 0 0}
.prog-block-num{font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:2px;padding:3px 9px;border-radius:5px;flex-shrink:0}
.sprint-hdr .prog-block-num{background:var(--y);color:var(--black)}
.ball-hdr .prog-block-num{background:#4FC3F7;color:#000}
.prog-block-title{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:1px;flex:1}
.sprint-hdr .prog-block-title{color:#fff}
.ball-hdr .prog-block-title{color:#fff}
.prog-block-meta{font-size:16px;font-weight:600;letter-spacing:.5px;flex-shrink:0}
.sprint-hdr .prog-block-meta{color:rgba(255,255,255,.4)}
.ball-hdr .prog-block-meta{color:rgba(255,255,255,.4)}
.

.prog-block-body{background:var(--card);padding:4px 12px 12px}


/* PHASE */
.plbl{font-size:16px;letter-spacing:2px;text-transform:uppercase;color:var(--y2);font-weight:800;margin:13px 0 7px;display:flex;align-items:center;gap:8px}
.plbl::after{content:'';flex:1;height:1px;background:var(--border)}
.plbl.blue{color:#4FC3F7}
.plbl.blue::after{background:rgba(79,195,247,.2)}

/* EXERCISE ROW */
/* Exercise row - pure div, no checkbox dependency */
.exrow{
  background:var(--bg);border-radius:11px;padding:14px 13px;
  margin-bottom:8px;display:flex;align-items:center;gap:12px;
  border:1.5px solid var(--border);transition:opacity .2s;
  cursor:pointer;touch-action:manipulation;
  -webkit-tap-highlight-color:rgba(255,214,0,.15);
  user-select:none;
}
.exrow.done{opacity:.45}
.exrow.done .exname{text-decoration:line-through}
.excheck{
  width:44px;height:44px;border-radius:50%;
  border:2px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;font-size:18px;background:#fff;
  transition:all .2s;pointer-events:none;flex-shrink:0;
}
.exinfo{flex:1;min-width:0}
.exname{font-size:18px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--text)}
.exsets{font-size:17px;color:var(--muted);margin-top:2px}
.exlinks{display:flex;gap:4px;flex-shrink:0}
.exlink{display:flex;align-items:center;justify-content:center;width:48px;height:48px;border-radius:10px;text-decoration:none;font-size:20px;cursor:pointer;border:none;transition:background .15s}
.exlink.yt{background:rgba(198,40,40,.10)}
.exlink.tip{background:var(--yl);font-size:16px;font-weight:800;color:var(--black)}
.solo-tag{display:inline-block;font-size:16px;font-weight:800;color:var(--blue);background:rgba(21,101,192,.08);border:1px solid rgba(21,101,192,.2);border-radius:4px;padding:1px 5px;margin-left:5px;letter-spacing:.5px;vertical-align:middle}

/* REST / INFO CARDS */
.rest-card{background:var(--card);border-radius:var(--r);padding:26px 18px;border:1.5px solid var(--border);box-shadow:var(--sh);text-align:center}
.icard{background:var(--card);border-radius:var(--r);padding:15px;border:1.5px solid var(--border);box-shadow:var(--sh);margin-bottom:10px}

/* MEASURE BLOCK */
.meas-grid{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:6px;align-items:flex-end;margin-top:8px}
.meas-inp-lbl{font-size:16px;font-weight:700;color:var(--text2);margin-bottom:3px}
.meas-inp{width:100%;background:var(--bg);border:1.5px solid var(--border);border-radius:8px;font-size:20.8px;padding:8px 6px;font-family:'Barlow',sans-serif;font-weight:700;text-align:center;outline:none;color:var(--text)}
.meas-inp:focus{border-color:var(--y)}
.meas-best{background:var(--black);border-radius:8px;padding:9px 6px;font-family:'Bebas Neue',sans-serif;font-size:28.6px;color:var(--y);text-align:center;min-height:38px}
.meas-save{width:100%;background:var(--black);color:var(--y);border:none;border-radius:11px;font-family:'Barlow',sans-serif;font-weight:800;font-size:19.5px;padding:14px;cursor:pointer;margin-top:10px;letter-spacing:.3px}

/* SHOULDER CHECK */
.sc-box{background:var(--black);border-radius:13px;overflow:hidden;margin-bottom:8px}
.sc-screen{background:#0d0d0d;padding:20px;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:180px}
.sc-cue{font-family:'Bebas Neue',sans-serif;font-size:67.6px;color:var(--y);text-align:center;letter-spacing:2px;min-height:60px;display:flex;align-items:center;justify-content:center}
.sc-cue.pop{animation:pop .2s ease}
@keyframes pop{0%{transform:scale(.5);opacity:0}100%{transform:scale(1);opacity:1}}
.sc-info{font-size:16px;color:rgba(255,255,255,.35);text-align:center;margin-bottom:10px;line-height:1.5}
.sc-cnt{font-size:16px;color:rgba(255,255,255,.3);font-family:'Bebas Neue',sans-serif;letter-spacing:1px;margin-top:8px}
.sc-start{width:100%;background:var(--y);color:var(--black);border:none;border-radius:0 0 13px 13px;font-family:'Barlow',sans-serif;font-weight:800;font-size:18.2px;padding:13px;cursor:pointer;letter-spacing:.3px}
.sc-start.stop{background:rgba(198,40,40,.15);color:var(--red)}
.sc-yt{display:flex;align-items:center;gap:8px;padding:9px 14px;border-top:1px solid rgba(255,255,255,.06);text-decoration:none}
.sc-yt span:first-child{background:var(--red);color:#fff;font-size:16px;font-weight:800;padding:2px 6px;border-radius:4px;flex-shrink:0}
.sc-yt span:last-child{font-size:16px;color:rgba(255,255,255,.35);font-weight:600}

/* MODAL */
.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.72);z-index:300;align-items:flex-end;justify-content:center;padding:10px}
.ov.open{display:flex}
.modal{background:var(--card);border-radius:22px 22px 13px 13px;width:100%;max-width:600px;padding:20px;border:1.5px solid var(--border);max-height:80vh;overflow-y:auto;animation:su .25s ease;box-shadow:0 8px 32px rgba(0,0,0,.15)}
@keyframes su{from{transform:translateY(50px);opacity:0}to{transform:translateY(0);opacity:1}}
.mcls{float:right;background:var(--bg);border:none;color:var(--text);border-radius:50%;width:32px;height:32px;font-size:22.1px;cursor:pointer;line-height:32px;text-align:center}
.mtitle{font-family:'Bebas Neue',sans-serif;font-size:33.8px;color:var(--black);margin-bottom:2px}
.mex{font-size:16px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;font-weight:700;margin-bottom:13px;border-bottom:1.5px solid var(--border);padding-bottom:9px}
.titem{display:flex;gap:9px;margin-bottom:10px;align-items:flex-start}
.tdot{width:6px;height:6px;border-radius:50%;background:var(--y2);margin-top:5px;flex-shrink:0}
.ttext{font-size:16.9px;line-height:1.6;color:var(--text)}
.tkey{font-weight:800;color:var(--black)}
.twarn{background:#FFF3E0;border-left:3px solid #E65100;border-radius:0 8px 8px 0;padding:9px 12px;font-size:16px;color:#BF360C;margin-top:10px;line-height:1.5}
.tgood{background:#F1F8E9;border-left:3px solid #558B2F;border-radius:0 8px 8px 0;padding:9px 12px;font-size:16px;color:#2E7D32;margin-top:7px;line-height:1.5}
.ytbtn{display:flex;align-items:center;gap:9px;background:#FFF3F3;border:1px solid rgba(198,40,40,.25);border-radius:10px;padding:12px 14px;text-decoration:none;color:var(--text);margin-top:12px;font-size:16px;font-weight:700}
.ytbadge{background:var(--red);color:#fff;font-size:16px;font-weight:800;padding:2px 7px;border-radius:4px;flex-shrink:0}

/* RECORD MODAL */
.recgrid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:12px}
.recfg label{font-size:16px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--text2);display:block;margin-bottom:4px}
.recfg input{width:100%;background:var(--bg);border:1.5px solid var(--border);border-radius:9px;color:var(--text);font-family:'Barlow',sans-serif;font-size:24.7px;padding:11px 8px;outline:none;text-align:center;font-weight:700}
.recfg input:focus{border-color:var(--y)}
.recsave{width:100%;background:var(--y);color:var(--black);border:none;border-radius:11px;font-family:'Barlow',sans-serif;font-weight:800;font-size:19.5px;padding:13px;cursor:pointer;margin-top:12px}

/* TECHNIQUE */
.techitem{background:var(--card);border-radius:var(--r);padding:14px;margin-bottom:9px;border:1.5px solid var(--border);display:flex;gap:13px;box-shadow:var(--sh)}
.techico{font-size:33.8px;flex-shrink:0;width:40px;text-align:center;margin-top:2px}
.techname{font-size:18.2px;font-weight:800;margin-bottom:3px;color:var(--text)}
.techdesc{font-size:16px;color:var(--text2);line-height:1.6}
.techtip{font-size:16px;color:var(--green);margin-top:5px;font-weight:700}

/* REFERENCE */
.refcard{background:var(--card);border-radius:var(--r);padding:14px;border:1.5px solid var(--border);margin-bottom:8px;display:flex;align-items:center;gap:12px;box-shadow:var(--sh)}
.refl{flex:1} .reflbl{font-size:16px;font-weight:700;margin-bottom:6px;color:var(--text)}
.refbg{background:var(--bg2);border-radius:100px;height:8px;overflow:hidden}
.reffill{height:100%;border-radius:100px}
.refrange{font-size:16px;color:var(--muted);margin-top:3px}
.refnum{font-family:'Bebas Neue',sans-serif;font-size:28.6px;flex-shrink:0;min-width:46px;text-align:right}
.youmark{background:var(--yl);border:1.5px solid var(--yb);border-radius:8px;padding:7px 11px;font-size:16px;font-weight:700;color:var(--black);margin-bottom:10px;text-align:center;display:none}

/* ANALYSE */
.spinner{width:18px;height:18px;border:2px solid var(--border);border-top-color:var(--y2);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

.botpad{height:30px}

/* ── QUOTE BAR ── */
.quote-bar{
  background:var(--card);border-radius:12px;padding:14px 16px;
  margin-bottom:10px;border:1.5px solid var(--border);box-shadow:var(--sh);
}
.quote-bar-title{
  font-size:16px;font-weight:800;color:var(--text);margin-bottom:10px;
  display:flex;align-items:center;justify-content:space-between;
}
.quote-row{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.quote-label{font-size:16px;font-weight:700;min-width:110px;color:var(--text2)}
.quote-bg{flex:1;background:var(--bg2);border-radius:100px;height:12px;overflow:hidden}
.quote-fill{height:100%;border-radius:100px;transition:width .5s ease}
.quote-fill.sprint{background:var(--y)}
.quote-fill.ball{background:#4FC3F7}
.quote-pct{font-size:16px;font-weight:800;min-width:38px;text-align:right}
.quote-count{font-size:16px;color:var(--muted);min-width:50px;text-align:right}
.quote-save-btn{
  width:100%;background:var(--black);color:var(--y);border:none;border-radius:10px;
  font-family:'Barlow',sans-serif;font-weight:800;font-size:16px;padding:13px;
  cursor:pointer;margin-top:10px;letter-spacing:.3px;
}

/* ── WEEKLY HISTORY ── */
.hist-entry{
  background:var(--bg);border-radius:11px;padding:12px 14px;
  margin-bottom:7px;border:1.5px solid var(--border);
}
.hist-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.hist-day{font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:800;color:var(--text)}
.hist-date{font-size:16px;color:var(--muted)}
