// ═══════════════════════
//  HISTORY / VERLAUF
// ═══════════════════════
function renderHistoryPanel(){
  if(!CP) return;
  const hist=DB.hist(CP.id);
  const summary=document.getElementById('hist_summary');
  const entries=document.getElementById('hist_entries');
  if(!summary||!entries) return;

  if(!hist.length){
    summary.innerHTML='';
    entries.innerHTML=`<div style="font-size:15.6px;color:var(--muted);text-align:center;padding:20px">Noch keine Einträge.<br>Übungen abhaken und Tag speichern!</div>`;
    return;
  }

  // Summary: average per block across all entries
  const spAvg=Math.round(hist.reduce((a,e)=>a+e.sprint.pct,0)/hist.length);
  const blAvg=Math.round(hist.reduce((a,e)=>a+e.ball.pct,0)/hist.length);
  const overall=Math.round((spAvg+blAvg)/2);
  const streak=calcStreak(hist);

  summary.innerHTML=`
    <div class="icard" style="background:var(--black);border-color:var(--black)">
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;text-align:center">
        <div>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:42px;color:var(--y);line-height:1">${overall}%</div>
          <div style="font-size:17px;color:rgba(255,255,255,.4);font-weight:700;margin-top:2px">Gesamt Ø</div>
        </div>
        <div>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:42px;color:var(--y);line-height:1">${spAvg}%</div>
          <div style="font-size:17px;color:rgba(255,255,255,.4);font-weight:700;margin-top:2px">⚡ Sprint Ø</div>
        </div>
        <div>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:42px;color:#4FC3F7;line-height:1">${blAvg}%</div>
          <div style="font-size:17px;color:rgba(255,255,255,.4);font-weight:700;margin-top:2px">⚽ Ball Ø</div>
        </div>
      </div>
      <div style="margin-top:12px;text-align:center;font-size:17px;color:rgba(255,255,255,.4);font-weight:700">
        🔥 ${streak} ${streak===1?'Tag':'Tage'} in Folge · ${hist.length} Einträge gesamt
      </div>
    </div>`;

  // Group by week
  const byWeek={};
  hist.forEach(e=>{
    const w='Woche '+e.week;
    if(!byWeek[w]) byWeek[w]=[];
    byWeek[w].push(e);
  });

  let html='';
  Object.keys(byWeek).sort((a,b)=>parseInt(b.split(' ')[1])-parseInt(a.split(' ')[1])).forEach(week=>{
    const wEntries=byWeek[week];
    const wSpAvg=Math.round(wEntries.reduce((a,e)=>a+e.sprint.pct,0)/wEntries.length);
    const wBlAvg=Math.round(wEntries.reduce((a,e)=>a+e.ball.pct,0)/wEntries.length);
    html+=`<div style="font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:800;color:var(--black);margin:14px 0 8px;letter-spacing:.5px;display:flex;align-items:center;justify-content:space-between">
      <span>${week}</span>
      <span style="font-size:17px;color:var(--muted);font-weight:700">Sprint Ø ${wSpAvg}% · Ball Ø ${wBlAvg}%</span>
    </div>`;
    wEntries.forEach((e,i)=>{
      const spColor=e.sprint.pct>=80?'#2E7D32':e.sprint.pct>=50?'#F9A825':'#C62828';
      const blColor=e.ball.pct>=80?'#1565C0':e.ball.pct>=50?'#4FC3F7':'#C62828';
      html+=`<div class="hist-entry">
        <div class="hist-header">
          <div class="hist-day">${e.dayLabel}</div>
          <div style="display:flex;align-items:center;gap:8px">
            <div class="hist-date">${e.date}</div>
            <button onclick="deleteHistEntry(${hist.indexOf(e)})" style="background:none;border:none;color:var(--muted);font-size:18px;cursor:pointer;padding:2px 6px">🗑</button>
          </div>
        </div>
        <div class="hist-mini-row">
          <div class="hist-mini-lbl">⚡ MaxSprint</div>
          <div class="hist-mini-bg"><div class="hist-mini-fill" style="width:${e.sprint.pct}%;background:${spColor}"></div></div>
          <div class="hist-mini-pct" style="color:${spColor}">${e.sprint.pct}%</div>
          <div style="font-size:17px;color:var(--muted);min-width:36px;text-align:right">${e.sprint.done}/${e.sprint.total}</div>
        </div>
        <div class="hist-mini-row">
          <div class="hist-mini-lbl">⚽ BallMaster</div>
          <div class="hist-mini-bg"><div class="hist-mini-fill" style="width:${e.ball.pct}%;background:${blColor}"></div></div>
          <div class="hist-mini-pct" style="color:${blColor}">${e.ball.pct}%</div>
          <div style="font-size:17px;color:var(--muted);min-width:36px;text-align:right">${e.ball.done}/${e.ball.total}</div>
        </div>
      </div>`;
    });
  });
  entries.innerHTML=html;
}

function calcStreak(hist){
  // Count consecutive days with at least one entry
  if(!hist.length) return 0;
  // Sort by date descending
  const sorted=[...hist].sort((a,b)=>new Date(b.date.split('.').reverse().join('-'))-new Date(a.date.split('.').reverse().join('-')));
  let streak=1;
  for(let i=1;i<sorted.length;i++){
    const a=new Date(sorted[i-1].date.split('.').reverse().join('-'));
    const b=new Date(sorted[i].date.split('.').reverse().join('-'));
    const diff=(a-b)/(1000*60*60*24);
    if(diff<=1) streak++;
    else break;
  }
  return streak;
}

function deleteHistEntry(idx){
  const hist=DB.hist(CP.id);
  hist.splice(idx,1);
  DB.savehist(CP.id,hist);
  renderHistoryPanel();
}

