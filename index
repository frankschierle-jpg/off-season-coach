function countExercisesFromPlan(dayKey){
  // Count directly from PLAN data - works before DOM is rendered
  var d = PLAN[dayKey];
  var result = {sprint:{done:0,total:0}, ball:{done:0,total:0}};
  if(!d) return result;
  ['sprint','ball'].forEach(function(type){
    var block = d[type];
    if(!block || !block.phases) return;
    var idx = 0;
    block.phases.forEach(function(ph){
      if(ph.sc || !ph.exs) return;
      ph.exs.forEach(function(ex){
        var id = 'ex_'+type+'_'+dayKey+'_'+idx;
        result[type].total++;
        if(CHECKED[id]) result[type].done++;
        idx++;
      });
    });
  });
  return result;
}
function countExercises(){
  return countExercisesFromPlan(curDay);
}

