function getMental(dayKey, weekOverride){
  const wsel = document.getElementById('wsel');
  const week = weekOverride || (wsel ? parseInt(wsel.value||'1') : 1);
  const weeks = getMENTAL();
  const w = weeks[week] || weeks[1];
  return w[dayKey] || null;
}

