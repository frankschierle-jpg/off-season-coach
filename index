function msBest(key){
  const vals=[1,2,3].map(i=>{const v=parseFloat(document.getElementById(`ms_${key}_${i}`)?.value);return isNaN(v)?null:v}).filter(v=>v!==null);
  const el=document.getElementById(`ms_${key}_best`);
