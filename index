function calcPrev(){
  const t10=parseFloat(document.getElementById('l_t10').value);
  const t20=parseFloat(document.getElementById('l_t20').value);
  const t50=parseFloat(document.getElementById('l_t50').value);
  const prev=document.getElementById('preview');
  if(isNaN(t10)&&isNaN(t20)&&isNaN(t50)){prev.style.display='none';return}
  let rows='';const pots=[];
  [{lbl:'10m',t:t10,B:B10,ifn:imp10,min:1.4,max:3.5},{lbl:'20m',t:t20,B:B20,ifn:imp20,min:2.2,max:5},{lbl:'50m',t:t50,B:B50,ifn:imp50,min:5.5,max:12}].forEach(d=>{
    if(!isNaN(d.t)&&d.t>=d.min&&d.t<=d.max){
      const g=grp(d.t,d.B),im=d.ifn(d.t),goal=(d.t-im).toFixed(2);
      rows+=`<div class="prev-row"><div class="prev-dist">${d.lbl}</div><div class="prev-right"><div class="prev-curr">${d.t.toFixed(2)}s</div><div class="prev-goal">Ziel: ${goal}s (−${im.toFixed(2)}s)</div><div class="prev-grp" style="color:${g.c}">${g.s}</div></div></div>`;
      pots.push(`${d.lbl}: −${im.toFixed(2)}s`);
    }
  });
  document.getElementById('prev_rows').innerHTML=rows;
  document.getElementById('prev_note').innerHTML=pots.join(' · ')+'<br><em style="color:var(--muted)">Größtes Potenzial: Technik Woche 1–2.</em>';
  prev.style.display='block';
}

function startApp(){
  try {
  const name=document.getElementById('l_name').value.trim();
  const age=parseInt(document.getElementById('l_age').value)||13;
  const height=parseFloat(document.getElementById('l_h').value);
  const weight=parseFloat(document.getElementById('l_w').value);
  const t10=parseFloat(document.getElementById('l_t10').value);
  const t20=parseFloat(document.getElementById('l_t20').value);
  const t50=parseFloat(document.getElementById('l_t50').value);
  if(!name){alert('Bitte Vornamen eingeben!');return}
  if(isNaN(height)||height<130||height>220){alert('Bitte Körpergröße eingeben (130–220 cm).');return}
  if(isNaN(weight)||weight<30||weight>120){alert('Bitte Körpergewicht eingeben (30–120 kg).');return}
  const any=(!isNaN(t10)&&t10>=1.4&&t10<=3.5)||(!isNaN(t20)&&t20>=2.2&&t20<=5)||(!isNaN(t50)&&t50>=5.5&&t50<=12);
  if(!any){alert('Bitte mindestens eine gültige Sprintzeit eingeben!');return}
  const today=ds();
  // Find existing player by name (case-insensitive)
  const all=DB.ps();
  let p=all.find(x=>x.name.trim().toLowerCase()===name.trim().toLowerCase());
  if(p){
    // Update existing - just update stats, keep history
    p.age=age; p.height=height; p.weight=weight;
    if(!isNaN(t10)&&t10>=1.4&&t10<=3.5) p.t10=t10;
    if(!isNaN(t20)&&t20>=2.2&&t20<=5) p.t20=t20;
    if(!isNaN(t50)&&t50>=5.5&&t50<=12) p.t50=t50;
    DB.save(p);
  } else {
    // New player
    p={
      id:Date.now().toString(),name,age,height,weight,week:1,createdAt:today,
      t10:(!isNaN(t10)&&t10>=1.4&&t10<=3.5)?t10:null,
      t20:(!isNaN(t20)&&t20>=2.2&&t20<=5)?t20:null,
      t50:(!isNaN(t50)&&t50>=5.5&&t50<=12)?t50:null,
      times10:(!isNaN(t10)&&t10>=1.4&&t10<=3.5)?[{d:today,v:t10}]:[],
      times20:(!isNaN(t20)&&t20>=2.2&&t20<=5)?[{d:today,v:t20}]:[],
      times50:(!isNaN(t50)&&t50>=5.5&&t50<=12)?[{d:today,v:t50}]:[],
    };
    DB.save(p);
  }
  DB.setcid(p.id);
  launch(p);
  } catch(err) {
    console.error('startApp error:', err);
    alert('Fehler beim Starten: ' + err.message);
  }
}

