}

function gngStartRound(){
  gng_round++;
  gng_results = [];
  gng_active = true;
  gng_waiting = false;
  var testIdx = gng_round - 1;
  var test = GNG_TESTS[testIdx] || GNG_TESTS[0];
  gng_variant = test.id;
  var btn = document.getElementById('gng_btn');
  if(btn){ btn.textContent = '⏹ Stoppen'; btn.style.background = 'rgba(231,76,60,.3)'; btn.style.color = '#E74C3C'; btn.onclick = function(){ gngStop(); }; }
  // Update instruction for current test
  var instrEl = document.getElementById('gng_instruction');
  if(instrEl){ instrEl.innerHTML = '<div style="font-size:16px;color:#fff;line-height:1.6;margin-bottom:8px">' + test.instruction + '</div><div style="font-size:16px"><span style="color:#27AE60;font-weight:800">✓ ' + test.goLabel + '</span></div><div style="font-size:16px;margin-top:4px"><span style="color:#E74C3C;font-weight:800">✗ ' + test.nogoLabel + '</span></div>'; }
  var titleEl = document.getElementById('gng_title');
  if(titleEl) titleEl.textContent = test.title;
  var sub = document.getElementById('gng_sub');
  if(sub) sub.textContent = 'Test ' + gng_round + ' von 3 läuft...';
  document.getElementById('gng_errors').textContent = '0';
  document.getElementById('gng_count').textContent = '0';
  document.getElementById('gng_avg').textContent = '--';
  document.getElementById('gng_save_btn').style.display = 'none';
  document.getElementById('gng_result_bar').style.display = 'none';
  setTimeout(gngNextCue, 800);
}

function gngNextCue(){
  if(!gng_active) return;
  // Stop after 50 stimuli
  if(gng_results.length >= 50){
    gngStopRound();
    return;
  }
  var test = GNG_TESTS[gng_round-1] || GNG_TESTS[0];
  var isGo = Math.random() < test.goRatio;
  var cueData = isGo ? test.getGo() : test.getNoGo();
  gng_cue_time = Date.now();
  gng_waiting = true;
  gng_current_is_go = isGo;
  var entry = {isGo: isGo, shown_at: gng_cue_time, responded: false, correct: false, rt: null, miss: false};
  gng_results.push(entry);
  var stim = document.getElementById('gng_stimulus');
  var fb = document.getElementById('gng_feedback');
  if(stim){
    stim.textContent = cueData.text;
    stim.style.color = cueData.color;
    stim.style.fontSize = cueData.size || '88px';
    stim.style.opacity = '1';
  }
  if(fb){ fb.textContent = ''; }
  // Show remaining count
  var sub = document.getElementById('gng_sub');
  if(sub) sub.textContent = (50 - gng_results.length + 1) + ' verbleibend';
  var idx = gng_results.length - 1;
  setTimeout(function(){
    if(gng_results[idx] && !gng_results[idx].responded){
      gng_results[idx].responded = true;
      if(gng_results[idx].isGo){
        gng_results[idx].correct = false;
        gng_results[idx].miss = true;
        var fb2 = document.getElementById('gng_feedback');
        if(fb2){ fb2.textContent = 'VERPASST!'; fb2.style.color = '#E74C3C'; }
      } else {
        gng_results[idx].correct = true;
      }
      gngUpdateStats();
    }
    var s2 = document.getElementById('gng_stimulus');
    if(s2) s2.style.opacity = '0';
    gng_waiting = false;
    if(gng_active) setTimeout(gngNextCue, 400 + Math.random() * 700);
  }, 900);
}

function gngTap(){
  if(!gng_active || !gng_waiting) return;
  var now = Date.now();
  var idx = gng_results.length - 1;
  if(idx < 0 || gng_results[idx].responded) return;
  gng_results[idx].responded = true;
  gng_results[idx].rt = now - gng_results[idx].shown_at;
  var fb = document.getElementById('gng_feedback');
  if(gng_results[idx].isGo){
    gng_results[idx].correct = true;
    if(fb){ fb.textContent = '✓ ' + gng_results[idx].rt + 'ms'; fb.style.color = '#27AE60'; }
  } else {
    gng_results[idx].correct = false;
    if(fb){ fb.textContent = '✗ FALSCH'; fb.style.color = '#E74C3C'; }
  }
