.hist-mini-lbl{font-size:16px;color:var(--text2);min-width:80px;font-weight:700}
.hist-mini-bg{flex:1;background:var(--bg2);border-radius:100px;height:8px;overflow:hidden}
.hist-mini-fill{height:100%;border-radius:100px}
.hist-mini-pct{font-size:16px;font-weight:800;min-width:34px;text-align:right}

.pause-inline{font-size:16px;font-weight:700;color:#8B6800;background:rgba(255,214,0,.12);border-radius:5px;padding:3px 7px;margin-top:5px;display:inline-block;letter-spacing:.3px}
