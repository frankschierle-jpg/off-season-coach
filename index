function saveTraining(){
  const counts=countExercises();
  const sp=counts.sprint; const bl=counts.ball;
  const spPct=sp.total>0?Math.round((sp.done/sp.total)*100):0;
  const blPct=bl.total>0?Math.round((bl.done/bl.total)*100):0;
  if(sp.total===0&&bl.total===0){alert('Keine Übungen gefunden.');return}
  const today=ds();
  const week=parseInt(document.getElementById('wsel').value)||1;
  const entry={
    day:curDay, dayLabel:PLAN[curDay].lbl, date:today, week,
    sprint:{done:sp.done,total:sp.total,pct:spPct},
    ball:{done:bl.done,total:bl.total,pct:blPct},
  };
  // Save to history
  const hist=DB.hist(CP.id);
  const filtered=hist.filter(e=>!(e.day===entry.day&&e.week===entry.week));
  filtered.unshift(entry); if(filtered.length>42) filtered.pop();
  DB.savehist(CP.id,filtered);
  // Save last completed day
  DB.savelastday(CP.id,curDay,today);
  renderHistoryPanel();
  // Show success + next day preview
  const nextDay=getNextTrainingDay(curDay);
  const nextPlan=PLAN[nextDay];
  showTrainingSaved(entry, nextDay, nextPlan);
}

