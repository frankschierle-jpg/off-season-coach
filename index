function gngUpdateStats(){
  var allR = gng_results;
  var goHits = allR.filter(function(r){ return r.isGo && r.correct && r.rt; });
  var errors = allR.filter(function(r){ return !r.correct; }).length;
  var avg = goHits.length ? Math.round(goHits.reduce(function(a,r){ return a+r.rt; },0)/goHits.length) : null;
  var cnt = document.getElementById('gng_count');
  var avgEl = document.getElementById('gng_avg');
  var errEl = document.getElementById('gng_errors');
  if(cnt) cnt.textContent = allR.length;
