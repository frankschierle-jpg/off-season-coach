const DB={
  ps(){ try{return JSON.parse(localStorage.getItem('ost_players')||'[]')}catch{return[]} },
  sp(a){ localStorage.setItem('ost_players',JSON.stringify(a)) },
  get(id){ return this.ps().find(p=>p.id===id)||null },
  save(p){ const a=this.ps(),i=a.findIndex(x=>x.id===p.id); i>=0?a[i]=p:a.push(p); this.sp(a) },
